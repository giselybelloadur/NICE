	; ---- PAD 1: Feed RF 50 ohm ----
	(pad "1" smd rect
		(at 0 0)
		(size 2 1.5)
		(layers "F.Cu" "F.Paste" "F.Mask")
		(uuid "22000060-0000-4000-8000-000000000001")
	)

	; ================================================================
	; Meander serpentina — apenas F.Cu — sem vias — sem B.Cu
	; Total: 4 segmentos x 19mm + 3 curvas x 2mm = 82mm = lambda/4 @ 915MHz
	; Trace width: 1.5mm | Gap: 0.5mm | Pitch: 2mm
	; ================================================================

	; Segmento 1: esquerda → direita  (y = 0)
	(fp_line
		(start 0 0)
		(end 19 0)
		(stroke (width 1.5) (type solid))
		(layer "F.Cu")
		(uuid "22000010-0000-4000-8000-000000000001")
	)
	; Curva 1: lado direito (y = 0 → y = -2)
	(fp_line
		(start 19 0)
		(end 19 -2)
		(stroke (width 1.5) (type solid))
		(layer "F.Cu")
		(uuid "22000010-0000-4000-8000-000000000002")
	)
	; Segmento 2: direita → esquerda  (y = -2)
