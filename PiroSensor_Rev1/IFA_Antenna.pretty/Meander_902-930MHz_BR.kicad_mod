		(layer "F.Cu")
		(uuid "22000010-0000-4000-8000-000000000006")
	)
	; Segmento 4: direita → esquerda  (y = -6) — extremidade aberta
	(fp_line
		(start 19 -6)
		(end 0 -6)
		(stroke (width 1.5) (type solid))
		(layer "F.Cu")
		(uuid "22000010-0000-4000-8000-000000000007")
